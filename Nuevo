local function Teleport(x, y, z)
    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = CFrame.new(x, y + 30, z)
        task.wait(0.2)
        root.CFrame = CFrame.new(x, y + 10, z)
    end
end

